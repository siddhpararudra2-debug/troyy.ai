# General App Settings
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=local-dev-secret-key
API_V1_STR=/api/v1
PROJECT_NAME="Engineering OS API"
CORS_ORIGINS=["*"]

# Database Connectivity (Using local SQLite instead of Supabase)
DATABASE_URL=sqlite+aiosqlite:///./troy.db

# Vector DB (Using local SQLite instead of Supabase)
VECTOR_DB_URL=sqlite+aiosqlite:///./troy.db

# Supabase Configurations (Mocked to allow app to start)
SUPABASE_URL=https://mock.supabase.co
SUPABASE_SERVICE_KEY=mock-key
SUPABASE_ANON_KEY=mock-key

# Redis Configuration (Mocked or local)
REDIS_URL=redis://localhost:6379/0

# Self-Hosted AI Infrastructure
OLLAMA_URL=http://127.0.0.1:11434
DEFAULT_MODEL=qwen2.5:32b
FALLBACK_MODEL=gemma2:9b

# Metrics / Logging
LOG_LEVEL=debug
