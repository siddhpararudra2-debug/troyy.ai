# -----------------------------------------------------------------------------
# PRODUCTION ENVIRONMENT VARIABLES TEMPLATE
# -----------------------------------------------------------------------------
# DO NOT COMMIT SECRETS TO VERSION CONTROL!
# Make a copy of this file and fill in your production values.

# General App Settings
ENVIRONMENT=production
DEBUG=False
SECRET_KEY=your-super-secret-key-for-fastapi-sessions-or-jwt
API_V1_STR=/api/v1
PROJECT_NAME="Engineering OS API"
CORS_ORIGINS=["https://your-frontend-domain.com", "https://www.your-frontend-domain.com"]

# Supabase Configurations
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key-do-not-share
SUPABASE_ANON_KEY=your-supabase-anon-key

# Database Connectivity (Supabase Transaction Pooler)
# Recommend using port 6543 for pgBouncer connection pooling
DATABASE_URL=postgresql://postgres.your-project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres

# Redis Configuration
REDIS_URL=redis://eos-redis:6379/0

# Vector DB (If external to Supabase)
VECTOR_DB_URL=postgresql://postgres.your-project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres

# Self-Hosted AI Infrastructure
# Make sure your local workstation IP / Tunnel URL is accessible from your VPS
OLLAMA_URL=http://your-ollama-server-ip:11434
DEFAULT_MODEL=qwen2.5:32b
FALLBACK_MODEL=gemma2:9b

# Metrics / Logging
LOG_LEVEL=info
SENTRY_DSN=your-sentry-dsn-optional
